{
    "manifest_version": 3,
    "name": "Google Forms AI Auto-Filler",
    "version": "2.4.6",
    "description": "Automatically extract context from Google Forms and intelligently fill answers using AI.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "alarms"
    ],
    "host_permissions": [
        "*://docs.google.com/forms/*",
        "https://formbhar-backend-7ir1.onrender.com/*",
        "https://api.openai.com/*",
        "https://generativelanguage.googleapis.com/*",
        "https://api.anthropic.com/*",
        "https://raw.githubusercontent.com/*"
    ],
    "background": {
        "service_worker": "background/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "*://docs.google.com/forms/*"
            ],
            "js": [
                "content/formReader.js",
                "content/formFiller.js",
                "content/domObserver.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}